{
  "name": "vatprc-uniapi-e2e",
  "private": true,
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "generate:api": "openapi-typescript ${OPENAPI_URL:-http://localhost:3000/openapi.json} --export-type -o lib/api/schema.ts",
    "test": "pnpm run build && ava"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.0.6",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.0.0",
    "ava": "^8.0.0",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3"
  },
  "ava": {
    "files": [
      "dist/**/*.test.js"
    ],
    "timeout": "90s",
    "workerThreads": true
  }
}
