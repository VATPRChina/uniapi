{
  "compilerOptions": {
    "noEmit": true,
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node", "vitest"],
    "strictNullChecks": false
  },
  "include": ["src/**/*.ts", "lib/**/*.ts"]
}
